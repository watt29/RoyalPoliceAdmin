# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=8314227996:AAHvGey8TKW7IZEKHVJE6dd_yyGJbEdFJdI
ADMIN_CHAT_ID=6734965582
BOT_USERNAME=police_ddb_bot

# Google Sheets Configuration
GOOGLE_SHEET_NAME=Smart_Memo_Database
GOOGLE_SHEET_ID=1xxwyReavlHXmKqEIEdem7zUAdlVS5Kv2D_7S6Rsf2UA
GOOGLE_DRIVE_FOLDER_ID=1W7HAAqSSLNpRMmIKbtqjmm_ayp_PnBOT

# Local Development (สำหรับการพัฒนาเท่านั้น)
GOOGLE_CREDENTIALS_PATH=service_account.json

# Production (Render.com) - ใส่ JSON ทั้งหมดของ service account
GOOGLE_CREDENTIALS={"type":"service_account","project_id":"..."}

# Server Configuration
NODE_ENV=production
PORT=3000

# Security & Rate Limiting
RATE_LIMIT_WINDOW=900000
RATE_LIMIT_MAX_REQUESTS=100

# File Management
MAX_FILE_SIZE=52428800
MAX_FILES_PER_USER=100
MAX_TEXT_FILE_SIZE=1048576

# Cache Settings
MAX_CACHE_SIZE=1000
CACHE_TIMEOUT=300000

# Optional: Keep-alive for free hosting
RENDER_SERVICE_NAME=your-render-service-name
KEEP_ALIVE_URL=https://your-app.onrender.com

# Optional: Database Settings (for future use)
# DATABASE_URL=your_database_connection_string

# Optional: Logging Settings
LOG_LEVEL=info
LOG_TO_FILE=true

# Optional: Backup Settings
BACKUP_INTERVAL=daily
BACKUP_RETENTION_DAYS=30

# Optional: Performance
MEMORY_LIMIT=512
CPU_LIMIT=1